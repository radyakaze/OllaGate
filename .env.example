# Example environment variables
# Copy this file to .env and fill in your actual values

# API Keys for Ollama (API_KEY_1, API_KEY_2, ... API_KEY_100)
API_KEY_1=your-api-key-1
API_KEY_2=your-api-key-2
API_KEY_3=your-api-key-3

# Local authentication token
LOCAL_KEY=my-secret-token

# Rate limit cooldown in seconds
RATE_LIMIT_COOLDOWN=60

# Enable Prometheus metrics endpoint
METRICS_ENABLED=false
